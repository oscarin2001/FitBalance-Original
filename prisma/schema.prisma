// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id                        Int                  @id @default(autoincrement())
  nombre                    String
  apellido                  String
  fecha_nacimiento          DateTime
  sexo                      String
  altura_cm                 Float?
  peso_kg                   Float?
  objetivo                  Objetivo?
  nivel_actividad           NivelActividad?
  pais                      String?
  peso_objetivo_kg          Float?
  velocidad_cambio          VelocidadCambio?
  tipo_entrenamiento        TipoEntrenamiento?
  nivel_experiencia         NivelExperiencia?
  frecuencia_entreno        Int?
  anos_entrenando           Float?
  terminos_aceptados        Boolean              @default(false)
  fecha_creacion            DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  comidas                   Comida[]
  progreso                  ProgresoCorporal[]
  auth                      Auth?
  onboarding_completed      Boolean              @default(false)
  onboarding_step           String?
  preferencias_alimentos    Json?
  kcal_objetivo             Float?
  proteinas_g_obj           Float?
  grasas_g_obj              Float?
  carbohidratos_g_obj       Float?
  agua_litros_obj           Float?
  objetivo_eta_semanas      Float?
  objetivo_eta_fecha        DateTime?
  plan_ai                   Json?
  hidratacion               HidratacionDia[]
  planes                    PlanComida[]
  cumplimientos             CumplimientoComida[]
  cumplimientos_dieta       CumplimientoDieta[]
  alimentos_seleccion       UsuarioAlimento[]
  bebidas_plan              UsuarioBebida[]
  measurement_interval_weeks Int?
  dias_dieta                Json?
}

model Auth {
  id                 Int      @id @default(autoincrement())
  usuario            Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId          Int      @unique
  email              String   @unique
  password_hash      String
  verificado         Boolean  @default(false)
  token_verificacion String?
  token_verificacion_expira DateTime?
  reset_token        String?
  last_login         DateTime?
}

model Alimento {
  id              Int                @id @default(autoincrement())
  nombre          String
  categoria       String?
  categoria_enum  AlimentoCategoria?
  calorias        Float?
  proteinas       Float?
  carbohidratos   Float?
  grasas          Float?
  porcion         String?
  region          String?
  comidas         Comida[]
  recetas         RecetaAlimento[]
  usuarios        UsuarioAlimento[]
  usuario_bebidas UsuarioBebida[]
}

model Receta {
  id            Int              @id @default(autoincrement())
  nombre        String
  instrucciones String?
  porciones     Int              @default(1)
  tipo          ComidaTipo?
  alimentos     RecetaAlimento[]
  comidas       Comida[]
  planes        PlanComida[]
}

model RecetaAlimento {
  id         Int      @id @default(autoincrement())
  receta     Receta   @relation(fields: [recetaId], references: [id])
  recetaId   Int
  alimento   Alimento @relation(fields: [alimentoId], references: [id])
  alimentoId Int
  gramos     Float
}

model Comida {
  id            Int        @id @default(autoincrement())
  usuario       Usuario    @relation(fields: [usuarioId], references: [id])
  usuarioId     Int
  fecha         DateTime
  comida_tipo   ComidaTipo
  receta        Receta?    @relation(fields: [recetaId], references: [id])
  recetaId      Int?
  alimento      Alimento?  @relation(fields: [alimentoId], references: [id])
  alimentoId    Int?
  gramos        Float?
  calorias      Float?
  proteinas     Float?
  carbohidratos Float?
  grasas        Float?
}

model HidratacionDia {
  id         Int      @id @default(autoincrement())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId  Int
  fecha      DateTime
  litros     Float    @default(0)
  completado Boolean  @default(false)

  @@index([usuarioId, fecha])
}

model ProgresoCorporal {
  id              Int      @id @default(autoincrement())
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId       Int
  fecha           DateTime
  peso_kg         Float?
  grasa_percent   Float?
  musculo_percent Float?
  agua_percent    Float?
  imc             Float?
  cintura_cm      Float?
  cadera_cm       Float?
  cuello_cm       Float?
  pecho_cm        Float?
  brazo_cm        Float?
  muslo_cm        Float?
  gluteo_cm       Float?
  foto_url        String?
  notas           String?
  fuente          String?

  @@unique([usuarioId, fecha])
  @@index([usuarioId, fecha])
}

model PlanComida {
  id          Int        @id @default(autoincrement())
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])
  usuarioId   Int
  fecha       DateTime
  comida_tipo ComidaTipo
  receta      Receta     @relation(fields: [recetaId], references: [id])
  recetaId    Int
  porciones   Int        @default(1)
  overrides   Json?

  @@index([usuarioId, fecha])
  @@unique([usuarioId, fecha, comida_tipo])
}

model CumplimientoComida {
  id          Int        @id @default(autoincrement())
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])
  usuarioId   Int
  fecha       DateTime
  comida_tipo ComidaTipo
  cumplido    Boolean    @default(false)
  hora_real   DateTime?

  @@index([usuarioId, fecha, comida_tipo])
  @@unique([usuarioId, fecha, comida_tipo])
}

model CumplimientoDieta {
  id        Int      @id @default(autoincrement())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  fecha     DateTime
  cumplido  Boolean
}

// N:N explicit relation between Usuario and Alimento for onboarding and preferences
model UsuarioAlimento {
  id            Int               @id @default(autoincrement())
  usuario       Usuario           @relation(fields: [usuarioId], references: [id])
  usuarioId     Int
  alimento      Alimento          @relation(fields: [alimentoId], references: [id])
  alimentoId    Int
  categoria     String?
  categoria_enum AlimentoCategoria?
  prioridad     Int?

  @@unique([usuarioId, alimentoId])
}

// Daily beverage plan suggestions
model UsuarioBebida {
  id        Int      @id @default(autoincrement())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  bebida    Alimento @relation(fields: [bebidaId], references: [id])
  bebidaId  Int
  ml        Int
  momento   String?

  @@index([usuarioId])
}

enum Objetivo {
  Bajar_grasa
  Ganar_musculo
  Mantenimiento
}

enum ComidaTipo {
  Desayuno
  Almuerzo
  Cena
  Snack
}

enum NivelActividad {
  Sedentario
  Ligero
  Moderado
  Activo
  Extremo
}

enum VelocidadCambio {
  Rapido
  Moderado
  Lento
}

enum TipoEntrenamiento {
  No_entrena
  Cardio
  Mixto
  Musculacion
}

enum NivelExperiencia {
  Principiante
  Intermedio
  Avanzado
}

enum AlimentoCategoria {
  Proteinas
  Carbohidratos
  Fibras
  Snacks
  Grasos
  Frutos
  Verduras
  BebidasInfusiones
}
